generator client {
  provider = "prisma-client-js"
  engineType = "library"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model inventory {
  id                  Int      @id @default(autoincrement())
  part_name           String?  @db.VarChar(255)
  drawing_no          String?  @db.VarChar(255)
  product_description String?
  part_group          String?  @db.VarChar(255)
  material            String?  @db.VarChar(255)
  detail1             String?  @db.VarChar(255)
  detail2             String?  @db.VarChar(255)
  category            String?  @db.VarChar(255)
  reg_no              String?  @db.VarChar(255)
  sku                 String?  @unique @db.VarChar(255)
  vendor              String?  @db.VarChar(255)
  location            String?  @db.VarChar(255)
  available_qty       Int?     @default(0)
  unit                String?  @db.VarChar(50)
  price               Decimal? @default(0.00) @db.Decimal(10, 2)
  rate                Decimal? @default(0.00) @db.Decimal(10, 2)
}

model pending_requests {
  id               String    @id @db.VarChar(100)
  part_name        String?   @db.VarChar(255)
  qty              String?   @db.VarChar(50)
  size             String?   @db.VarChar(100)
  material         String?   @db.VarChar(100)
  machine          String?   @db.VarChar(255)
  vendor           String?   @db.VarChar(255)
  requested_by     String?   @db.VarChar(255)
  received_at      DateTime? @default(now()) @db.Timestamptz(6)
  sku              String?   @db.VarChar(100)
  category         String?   @db.VarChar(100)
  price            String?   @db.VarChar(100)
  available_stock  String?   @db.VarChar(100)
  stock_warning    String?
  suggested_match  String?
  demand_timestamp DateTime? @default(now()) @db.Timestamptz(6)
  rate             String?   @db.VarChar(100)
  status           String?   @default("pending_review") @db.VarChar(50)
  approved_by      String?   @db.VarChar(255)
  approved_at      DateTime? @db.Timestamptz(6)
  edited_by        String?   @db.VarChar(255)
  edited_at        DateTime? @db.Timestamptz(6)
  forwarded_at     DateTime? @db.Timestamptz(6)
  reg_no           String?   @db.VarChar(255)
  unit             String?   @db.VarChar(50)
  is_ordered       Boolean?  @default(false)
}

model whatsapp_groups {
  id         Int       @id @default(autoincrement())
  group_id   String?   @unique @db.VarChar(100)
  group_name String?   @db.VarChar(255)
  active     Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}
